<script>
    function initLogoAnimation() {
        const container = document.getElementById("animated-logo-container") as HTMLElement | null;
        const svg = document.getElementById("logo-svg") as HTMLElement | null;
        const fades = document.querySelectorAll(".fade-letter") as NodeListOf<HTMLElement>;
        const slashes = document.querySelectorAll(".slash") as NodeListOf<HTMLElement>;

        if (!container || !svg || !fades.length || !slashes.length) return;

        const maxScroll = 150;
        const mobileBreakpoint = 768;

        // The user explicitly defined the right-to-left fade order via IDs:
        // Grouping ["I", "R", "H1"] to fade together at the end.
        const explicitFadeOrder = ["E", "W", "O", "H", "S", ["I", "R", "H1"]];

        // Process elements and group them
        const explicitFades = explicitFadeOrder
            .map((group) => {
                if (Array.isArray(group)) {
                    return group.map((id) => document.getElementById(id)).filter((el) => el !== null) as HTMLElement[];
                }
                const el = document.getElementById(group);
                return el ? [el] : [];
            })
            .filter((group) => group.length > 0);

        let targetProgress = 1; // 1 = collapsed, 0 = expanded
        let currentProgress = 1;
        let startProgress = 1;
        let animationStartTime = 0;
        const animationDuration = 600; // ms
        let isAnimating = false;
        let lastTarget: number | null = null;

        function easeInOutCubic(t: number) {
            return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
        }

        function renderDOM(progress: number) {
            currentProgress = progress;
            const originalWidth = 174.87 - 141.94 * progress;
            const visualWidth = originalWidth * 0.8; // 20% smaller overall display

            container!.style.width = `${visualWidth}px`;
            svg!.setAttribute("viewBox", `0 0 ${originalWidth} 15.61`);
            svg!.style.width = `${visualWidth}px`;

            const slashOffset = -141.94 * progress;

            // Apply opacity based on their explicitly defined order
            const fadeEndProgress = 0.6; // All letters vanish by 60% of the movement
            explicitFades.forEach((group, index) => {
                const total = explicitFades.length;

                // Divide the 60% window into equal slices for each group
                const startP = (index / total) * fadeEndProgress;
                const endP = ((index + 1) / total) * fadeEndProgress;

                // Math.max/min to clamp it between 0 and 1
                let localProgress = (progress - startP) / (endP - startP);
                localProgress = Math.max(0, Math.min(1, localProgress));

                // Fourth-power curve for a very aggressive snap to zero opacity
                const opacity = Math.max(1 - Math.pow(localProgress, 4), 0);

                group.forEach((el) => {
                    el.style.opacity = opacity.toString();
                });
            });

            // Still need to apply the global transform shift to all fade-letters to keep them morphing
            fades.forEach((el) => {
                el.style.transform = `translateX(${-20 * progress}px)`;
            });

            slashes.forEach((el) => {
                el.style.transform = `translateX(${slashOffset}px)`;
            });
        }

        function animate(timestamp: number) {
            if (!animationStartTime) animationStartTime = timestamp;
            const elapsed = timestamp - animationStartTime;
            let t = Math.min(elapsed / animationDuration, 1);

            const easedT = easeInOutCubic(t);
            const progress = startProgress + (targetProgress - startProgress) * easedT;

            renderDOM(progress);

            if (t < 1) {
                requestAnimationFrame(animate);
            } else {
                isAnimating = false;
            }
        }

        function handleScroll(instant = false) {
            const isMobile = window.innerWidth < mobileBreakpoint;
            // Scroll threshold. Collapsed if passed 50px.
            const shouldCollapse = isMobile ? true : window.scrollY > 50;
            const newTarget = shouldCollapse ? 1 : 0;

            if (newTarget !== lastTarget) {
                lastTarget = newTarget;
                targetProgress = newTarget;

                if (instant) {
                    renderDOM(newTarget);
                } else {
                    startProgress = currentProgress;
                    animationStartTime = 0; // reset
                    if (!isAnimating) {
                        isAnimating = true;
                        requestAnimationFrame(animate);
                    }
                }
            }
        }

        window.addEventListener("scroll", () => handleScroll(false), { passive: true });
        window.addEventListener("resize", () => handleScroll(false), { passive: true });
        handleScroll(true); // Snap to correct state instantly on load
    }

    document.addEventListener("astro:page-load", initLogoAnimation);
    if (document.readyState === "complete" || document.readyState === "interactive") {
        initLogoAnimation();
    } else {
        document.addEventListener("DOMContentLoaded", initLogoAnimation);
    }
</script>
