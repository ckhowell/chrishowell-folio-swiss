---
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
const featured = projects.filter((p) => p.data.isFeatured).sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

// Brand-tinted overlay colors per project
const projectColors: Record<string, string> = {
  erni: "#3a2d5c",
  arrow: "#1a1a2e",
  "city-of-gold-coast": "#1e3a3a",
  peerless: "#2e1e2e",
  exintech: "#1e2e3a",
  "no-pong": "#3a3420",
  "sunland-group": "#1e2e24",
  "qld-government": "#1a2640",
  allconnex: "#2a3020",
};
---

<style>
  .spotlight {
    position: relative;
    width: 100%;
    /* Keep the height as viewport units for pinning */
    height: 100vh;
    height: 100svh;
    padding: 0;
    overflow: hidden;
    -webkit-overflow-scrolling: touch;
  }

  /* Desktop breakpoint from original */
  @media (min-width: 1000px) {
    .spotlight {
      padding: 0;
    }
  }

  .project-images {
    position: relative;
    /* Let grid define width and alignment */
    padding: 50vh 0;
    padding: 50svh 0;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    z-index: 1;
  }

  .project-img {
    width: 100%;
    aspect-ratio: 16/9;
    opacity: 0.5;
    transition:
      opacity 0.5s cubic-bezier(0.5, 0, 0.25, 1),
      transform 0.5s cubic-bezier(0.5, 0, 0.25, 1),
      box-shadow 0.5s cubic-bezier(0.5, 0, 0.25, 1),
      border-radius 0.5s cubic-bezier(0.5, 0, 0.25, 1),
      margin 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    overflow: hidden;
    transform: translateZ(0) scale(1);
    border-radius: 1rem;
    will-change: transform, opacity, box-shadow;
    margin: 0;
    border: 0.625rem solid #fff;
  }

  .project-img.is-active {
    opacity: 1 !important;
    transform: scale(1.13) translateZ(0) !important;
    box-shadow: 0 40px 70px -20px rgba(0, 0, 0, 0.15);
    border-radius: 0;
    z-index: 20;
    margin: 2rem 0;
  }

  .project-index {
    position: absolute;
    top: 2rem;
    left: 0;
    width: 100%;
    z-index: 10;
  }

  .project-index h1 {
    text-transform: uppercase;
    font-size: clamp(3rem, 5vw, 7rem);
    font-weight: 400;
    line-height: 1;
  }

  .project-names {
    position: absolute;
    bottom: 2rem;
    left: 0;
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    z-index: 10;
  }

  .project-names p {
    color: #a0a0a0; /* Original inactive color */
    font-size: 0.8rem;
    font-weight: 500;
    line-height: 1.25;
    transition: color 0.3s ease;
    transform: translateZ(0);
  }

  .project-meta {
    display: flex;
    gap: 0.35rem;
    margin-top: 0.25rem;
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition:
      max-height 0.5s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.4s ease;
  }

  .project-meta.is-visible {
    max-height: 2rem;
    opacity: 1;
  }

  .project-meta-pill {
    display: inline-block;
    font-size: 0.55rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #555;
    clip-path: inset(0 100% 0 0);
    transition: clip-path 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .project-meta.is-visible .project-meta-pill {
    clip-path: inset(0 0% 0 0);
  }

  .project-index h4,
  .project-images,
  .project-names p {
    will-change: transform;
  }

  @media (max-width: 999px) {
    .project-images {
      width: 100%;
      gap: 1.5rem;
      padding-top: 25svh;
    }

    .project-names p {
      color: #000 !important;
    }

    /* Mobile inline captions under each image */
    .mobile-caption {
      display: block;
      padding: 0.5rem 0 0.75rem;
    }

    .mobile-caption-title {
      font-size: 0.8rem;
      font-weight: 500;
      line-height: 1.25;
      color: #1a1a1a;
    }

    .mobile-caption-meta {
      font-size: 0.55rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #888;
      margin-top: 0.15rem;
    }
  }

  /* Hide mobile captions on desktop */
  @media (min-width: 1000px) {
    .mobile-caption {
      display: none;
    }
  }
</style>

<section class="spotlight bg-[#f7f7f7] text-black z-10">
  <div class="-container h-full">
    <div class="-grid h-full relative">
      <!-- Counter Column (Cols 1-4 on desktop) -->
      <div class="col-span-full s:col-span-4 relative h-[100vh] self-start hidden">
        <div class="project-index">
          <h1>01/{featured.length.toString().padStart(2, "0")}</h1>
        </div>
      </div>

      <!-- Image Column (Cols 6-11 on desktop, centered) -->
      <div class="col-span-full s:col-span-3 s:col-start-4 project-images pt-[50vh] s:pt-[50vh]">
        {
          featured.map((project) => {
            const imgSrc = typeof project.data.image === "string" ? project.data.image : project.data.image[0];
            return (
              <div class="project-card">
                <a
                  href={`/work/${project.slug}`}
                  class="project-img aspect-[16/9] w-full opacity-50 transition-opacity duration-300 overflow-hidden translate-z-0 block"
                  data-cursor-text=">>"
                >
                  <img src={imgSrc} alt={project.data.title} loading="lazy" class="w-full h-full object-cover block" />
                </a>
                <div class="mobile-caption">
                  <p class="mobile-caption-title">{project.data.title}</p>
                  {project.data.industry && <p class="mobile-caption-meta">{project.data.industry}</p>}
                </div>
              </div>
            );
          })
        }
      </div>

      <!-- Names Column (Cols 8-12 on desktop) -->
      <div class="col-span-full s:col-span-4 s:col-start-8 relative h-[100vh] self-start">
        <div class="project-names">
          {
            featured.map((project) => (
              <a href={`/work/${project.slug}`} class="block transition-colors hover:text-black project-name-link">
                <p>{project.data.title}</p>
                <div class="project-meta" data-industry={project.data.industry}>
                  <span class="project-meta-pill">{project.data.industry}</span>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
