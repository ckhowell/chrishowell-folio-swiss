---
/**
 * CLI-style progress bar preloader.
 * HTML + CSS only — animation driven by router.ts
 */
---

<div id="preloader" class="preloader" aria-hidden="true">
    <div class="preloader__terminal">
        <div class="preloader__line">
            <span class="preloader__bar-wrapper">
                <span class="preloader__left">|</span><span id="preloader-bar" class="preloader__bar"></span><span id="preloader-blank" class="preloader__blank"
                ></span><span class="preloader__right">|</span>
            </span>
            <span id="preloader-percent" class="preloader__percent">&nbsp;&nbsp;0%</span>
        </div>
    </div>
</div>

<style is:global>
    .preloader {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: #f0f0f0;
        display: flex;
        align-items: flex-end;
        justify-content: flex-start;
        padding: 2rem;
        transition:
            opacity 0.5s ease,
            visibility 0.5s ease;
    }

    .preloader.--done {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
    }

    .preloader.--hidden {
        display: none !important;
    }

    .preloader__terminal {
        font-family: "SF Mono", "Fira Code", "Cascadia Code", "Consolas", monospace;
        font-size: clamp(0.65rem, 1.2vw, 0.85rem);
        color: #1a1a1a;
        line-height: 1;
        width: 100%;
        max-width: 480px;
    }

    .preloader__line {
        display: flex;
        align-items: center;
        white-space: nowrap;
    }

    .preloader__bar-wrapper {
        display: inline-flex;
        align-items: center;
        flex: 1;
        min-width: 0;
    }

    .preloader__left,
    .preloader__right {
        flex-shrink: 0;
        color: #888;
    }

    .preloader__bar {
        color: #1a1a1a;
        overflow: hidden;
        width: 0%;
        white-space: nowrap;
        direction: ltr;
    }

    .preloader__blank {
        color: #ccc;
        overflow: hidden;
        flex: 1;
        white-space: nowrap;
        direction: ltr;
    }

    .preloader__percent {
        flex-shrink: 0;
        margin-left: 0.75ch;
        text-align: right;
        min-width: 4ch;
        color: #888;
    }
</style>
