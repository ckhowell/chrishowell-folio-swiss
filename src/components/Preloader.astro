---
/**
 * CLI-style progress bar preloader.
 * Pure CSS animation — no JavaScript dependency for the visual.
 * The bar fills via CSS @keyframes, JS only handles cleanup.
 */
---

<div id="preloader" class="preloader" aria-hidden="true">
    <div class="preloader__terminal">
        <div class="preloader__line">
            <span class="preloader__bar-wrapper">
                <span class="preloader__left">|</span>
                <span class="preloader__fill"></span>
                <span class="preloader__right">|</span>
            </span>
        </div>
    </div>
</div>

<style is:global>
    /* ── PRELOADER ─────────────────────────────────────────────── */
    .preloader {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: #f0f0f0;
        display: flex;
        align-items: flex-end;
        justify-content: flex-start;
        padding: 2rem;
        /* Auto-fade after bar completes: 1.8s animation + 0.4s pause */
        animation: preloaderFadeOut 0.5s ease 2.2s forwards;
    }

    .preloader.--skip {
        display: none !important;
    }

    .preloader__terminal {
        font-family: "SF Mono", "Fira Code", "Cascadia Code", "Consolas", monospace;
        font-size: clamp(0.65rem, 1.2vw, 0.85rem);
        color: #1a1a1a;
        line-height: 1;
        width: 100%;
        max-width: 480px;
    }

    .preloader__line {
        display: flex;
        align-items: center;
        white-space: nowrap;
    }

    .preloader__bar-wrapper {
        display: flex;
        align-items: center;
        width: 100%;
    }

    .preloader__left,
    .preloader__right {
        flex-shrink: 0;
        color: #888;
    }

    .preloader__fill {
        flex: 1;
        height: 1em;
        position: relative;
        overflow: hidden;
    }

    .preloader__fill::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0;
        height: 100%;
        width: 0%;
        background: repeating-linear-gradient(90deg, #1a1a1a 0px, #1a1a1a 0.55em, transparent 0.55em, transparent 0.62em);
        animation: barFill 1.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
    }

    @keyframes barFill {
        0% {
            width: 0%;
        }
        100% {
            width: 100%;
        }
    }

    @keyframes preloaderFadeOut {
        0% {
            opacity: 1;
            pointer-events: auto;
        }
        100% {
            opacity: 0;
            pointer-events: none;
            visibility: hidden;
        }
    }
</style>
