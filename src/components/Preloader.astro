---
/**
 * CLI-style progress bar preloader.
 * Uses is:inline + IIFE for immediate execution.
 * setInterval-based for Safari compatibility.
 */
---

<div id="preloader" class="preloader" aria-hidden="true">
    <div class="preloader__terminal">
        <div class="preloader__line">
            <span class="preloader__bar-wrapper">
                <span class="preloader__left">|</span><span id="preloader-bar" class="preloader__bar"></span><span id="preloader-blank" class="preloader__blank"
                ></span><span class="preloader__right">|</span>
            </span>
            <span id="preloader-percent" class="preloader__percent">&nbsp;&nbsp;0%</span>
        </div>
    </div>
</div>

<script is:inline>
    // Immediately hide if already shown this session
    (function () {
        if (sessionStorage.getItem("ch_preloader_shown")) {
            var el = document.getElementById("preloader");
            if (el) el.style.display = "none";
        }
    })();
</script>

<style>
    .preloader {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: #f0f0f0;
        display: flex;
        align-items: flex-end;
        justify-content: flex-start;
        padding: 2rem;
        transition:
            opacity 0.5s ease,
            visibility 0.5s ease;
    }

    .preloader.--done {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
    }

    .preloader__terminal {
        font-family: "SF Mono", "Fira Code", "Cascadia Code", "Consolas", monospace;
        font-size: clamp(0.65rem, 1.2vw, 0.85rem);
        color: #1a1a1a;
        line-height: 1;
        width: 100%;
        max-width: 480px;
    }

    .preloader__line {
        display: flex;
        align-items: center;
        white-space: nowrap;
    }

    .preloader__bar-wrapper {
        display: inline-flex;
        align-items: center;
        flex: 1;
        min-width: 0;
    }

    .preloader__left,
    .preloader__right {
        flex-shrink: 0;
        color: #888;
    }

    .preloader__bar {
        color: #1a1a1a;
        overflow: hidden;
        width: 0%;
        white-space: nowrap;
        direction: ltr;
    }

    .preloader__blank {
        color: #ccc;
        overflow: hidden;
        flex: 1;
        white-space: nowrap;
        direction: ltr;
    }

    .preloader__percent {
        flex-shrink: 0;
        margin-left: 0.75ch;
        text-align: right;
        min-width: 4ch;
        color: #888;
    }
</style>

<script is:inline>
    // Animate the progress bar — runs immediately, no event listeners needed
    (function () {
        // Skip if already shown
        if (sessionStorage.getItem("ch_preloader_shown")) return;

        var preloader = document.getElementById("preloader");
        var barEl = document.getElementById("preloader-bar");
        var blankEl = document.getElementById("preloader-blank");
        var percentEl = document.getElementById("preloader-percent");

        if (!preloader || !barEl || !blankEl || !percentEl) return;

        var TOTAL = 50;
        var DURATION = 1800;
        var start = Date.now();
        var done = false;

        function ease(t) {
            return 1 - Math.pow(1 - t, 4);
        }

        function update() {
            if (done) return;
            var t = Math.min((Date.now() - start) / DURATION, 1);
            var pct = Math.round(ease(t) * 100);
            var filled = Math.round((pct / 100) * TOTAL);
            var empty = TOTAL - filled;

            barEl.textContent = Array(filled + 1).join("=");
            barEl.style.width = (filled / TOTAL) * 100 + "%";
            blankEl.textContent = Array(empty + 1).join(" ");
            blankEl.style.width = (empty / TOTAL) * 100 + "%";

            var s = String(pct);
            while (s.length < 3) s = "\u00A0" + s;
            percentEl.textContent = s + "%";

            if (pct >= 100) {
                done = true;
                clearInterval(timer);
                setTimeout(function () {
                    preloader.classList.add("--done");
                    sessionStorage.setItem("ch_preloader_shown", "true");
                    setTimeout(function () {
                        preloader.remove();
                    }, 600);
                }, 400);
            }
        }

        // Use setInterval — more reliable than rAF in Safari during initial page load
        var timer = setInterval(update, 16);
        update(); // Run first frame immediately
    })();
</script>
