---
import { getCollection } from "astro:content";

// Fetch featured projects and sort them by publish date
const projects = await getCollection("projects");
const featured = projects.filter((p) => p.data.isFeatured).sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());
---

<style>
    /* Base styles inspired by GSP CSS */
    .verticalSlider_root {
        width: 100%;
        position: relative;
        /* GSP padding converted roughly to rems */
        padding-top: 5rem;
        padding-bottom: 2.5rem;
    }

    /* Cards wrapper taking full viewport height */
    .verticalSlider_card {
        height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        position: relative;
        margin-bottom: 2.5rem;
    }
    .verticalSlider_card:last-of-type {
        margin-bottom: 0;
    }

    /* The actual image wrap - covers columns 3 to 10 on desktop */
    .verticalSlider_imageWrap {
        position: relative;
        width: 100%;
        height: 100%;
        max-height: 80vh; /* restrict height */
        overflow: hidden;
    }

    /* The image inside - scaled up initially for parallax */
    .verticalSlider_image {
        object-fit: cover;
        object-position: center;
        width: 100%;
        height: 120%; /* Extra height for parallax */
        clip-path: inset(100% 0 0 0); /* Used by GSAP clip reveal */
        transform: translateY(-10%); /* Starting parallax position */
        will-change: transform, clip-path;
    }

    /* The info overlay that stays sticky vertically in the center */
    .verticalSlider_content {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 20;
        pointer-events: none; /* Let clicks pass through to image */
    }

    .verticalSlider_information {
        position: sticky;
        top: 50%;
        transform: translateY(-50%);
    }

    /* Project Title (Left) */
    .verticalSlider_name {
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        align-items: flex-start;
        gap: 0;
        opacity: 0; /* GSAP animates this */
        transform: translateY(20px);
    }

    /* Project Industry (Right) */
    .verticalSlider_industry {
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        align-items: flex-start;
        gap: 0;
        opacity: 0; /* GSAP animates this */
        transform: translateY(20px);
    }

    .meta-label {
        color: #888;
        text-transform: uppercase;
        font-size: 0.65rem;
        letter-spacing: 0.05em;
        line-height: 1;
    }

    .meta-value {
        color: #000;
        font-size: 0.8rem;
        font-weight: 500;
        line-height: 1;
        margin-top: -0.05rem;
    }

    /* Mobile Layout overrides */
    @media screen and (max-width: 768px) {
        .verticalSlider_root {
            padding-top: 3.5rem;
        }
        .verticalSlider_card {
            height: 100vh; /* Using SVH if possible via JS, fallback to VH */
            height: 100svh;
            justify-content: flex-start;
            margin-bottom: 4rem;
        }
        .verticalSlider_content {
            position: relative;
            height: auto;
            top: 1rem;
        }
        .verticalSlider_information {
            position: relative;
            top: unset;
            transform: none;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }
        .verticalSlider_imageWrap {
            max-height: 60vh;
        }
        .verticalSlider_name,
        .verticalSlider_industry {
            opacity: 1; /* Keep visible on mobile without scroll triggers */
            transform: none;
            flex-direction: row;
            justify-content: space-between;
            width: 100%;
        }
    }
</style>

<div class="verticalSlider_root bg-[#f7f7f7] text-black z-10">
    {
        featured.map((project, index) => {
            // Handle the image whether it's an array or a single string
            const imgSrc = typeof project.data.image === "string" ? project.data.image : project.data.image[0];

            return (
                <div class="verticalSlider_card js-vertical-card" id={`card-${index}`}>
                    <div class="-container h-full w-full">
                        <div class="-grid h-full items-center relative">
                            <a
                                class="verticalSlider_imageWrap col-span-full s:col-span-4 s:col-start-3 block"
                                data-index={index}
                                data-cursor-text="view"
                                href={`/work/${project.slug}`}
                            >
                                <img
                                    src={imgSrc}
                                    alt={project.data.title}
                                    loading={index < 2 ? "eager" : "lazy"}
                                    decoding="async"
                                    class="verticalSlider_image js-clip-reveal"
                                />
                            </a>
                        </div>
                    </div>

                    <div class="verticalSlider_content">
                        <div class="-container h-full w-full">
                            <div class="verticalSlider_information -grid relative w-full">
                                <div class="verticalSlider_name col-span-full s:col-span-2 js-fade-up pointer-events-auto">
                                    <span class="meta-label">Project</span>
                                    <a class="meta-value uppercase hover:opacity-70 transition-opacity" href={`/work/${project.slug}`}>
                                        {project.data.title}
                                    </a>
                                </div>
                                <div class="verticalSlider_industry col-span-full s:col-span-2 s:col-start-8 js-fade-up">
                                    <span class="meta-label">Industry</span>
                                    <span class="meta-value uppercase">{project.data.industry || "-"}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            );
        })
    }
</div>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    // Use a resize observer to refresh triggers if layout changes
    const initGSAP = () => {
        // Determine if mobile
        const isMobile = window.matchMedia("(max-width: 768px)").matches;

        // 2. Card Animations (Clip Reveal, Parallax, Text Fade)
        const cards = document.querySelectorAll(".js-vertical-card");

        cards.forEach((card) => {
            const img = card.querySelector(".js-clip-reveal");
            const name = card.querySelector(".verticalSlider_name");
            const industry = card.querySelector(".verticalSlider_industry");

            // --- Clip Reveal Animation ---
            if (img) {
                gsap.to(img, {
                    clipPath: "inset(0% 0% 0% 0%)",
                    ease: "power2.out",
                    duration: 1.2,
                    scrollTrigger: {
                        trigger: card,
                        start: "top 80%", // slightly before the card hits screen center
                    },
                });

                // --- Image Parallax ---
                // Move image from translateY(-10%) to translateY(10%) inside the container over the course of its scroll.
                gsap.to(img, {
                    yPercent: 10,
                    ease: "none",
                    scrollTrigger: {
                        trigger: card,
                        start: "top bottom",
                        end: "bottom top",
                        scrub: true,
                    },
                });
            }

            // --- Text Fade Up Animation ---
            if (!isMobile) {
                // Desktop relies on a master timeline triggered when the card approaches center
                const tl = gsap.timeline({
                    scrollTrigger: {
                        trigger: card,
                        start: "top 60%", // start animating text when card is nearing center
                        toggleActions: "play reverse play reverse",
                    },
                });

                if (name && industry) {
                    // Stagger fade the info text up
                    tl.to([name, industry], {
                        y: 0,
                        opacity: 1,
                        duration: 0.6,
                        stagger: 0.1,
                        ease: "power2.out",
                    });

                    // Add a secondary ScrollTrigger to fade the text out when it leaves the top of the viewport
                    ScrollTrigger.create({
                        trigger: card,
                        start: "bottom 30%",
                        onEnter: () => gsap.to([name, industry], { opacity: 0, y: -20, duration: 0.4 }),
                        onLeaveBack: () => gsap.to([name, industry], { opacity: 1, y: 0, duration: 0.4 }),
                    });
                }
            }
        });
    };

    // Run on load and after View Transitions
    document.addEventListener("astro:page-load", () => {
        // small timeout to ensure DOM is fully repainted
        setTimeout(() => {
            initGSAP();
        }, 100);
    });
</script>
