---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
  currentPage?: string;
}

const { title, description, bodyClass = "", currentPage = "" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <ClientRouter fallback="animate" />
  </head>
  <body class={bodyClass} data-route-class={bodyClass}>
    <!-- Full-page color overlay for project hover effect -->
    <div class="color-overlay" aria-hidden="true"></div>

    <Header currentPage={currentPage} />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Custom cursor -->
    <div class="custom-cursor" aria-hidden="true">
      <div class="cursor-dot"></div>
      <div class="cursor-pill">
        <div class="cursor-pill-bg">
          <svg viewBox="0 0 100 100" class="w-full h-full">
            <circle cx="50" cy="50" r="50" fill="#1a1a1a"></circle>
          </svg>
        </div>
        <div class="cursor-text-wrap absolute inset-0 flex items-center justify-center">
          <span class="cursor-text"></span>
          <span class="cursor-text cursor-text--dupe hidden"></span>
        </div>
      </div>
    </div>

    <script>
      import "../scripts/router.ts";
    </script>
  </body>
</html>
