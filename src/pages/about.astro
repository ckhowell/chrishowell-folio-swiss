---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About | Chris Howell"
  bodyClass="about"
  currentPage="about"
>
  <section class="intro section pt-64 s:pt-160 pb-40 s:pb-100 s:min-h-screen">
    <!-- Back link -->
    <a
      href="/"
      class="fixed top-0 right-0 p-20 text-base font-medium z-50"
      data-animation="paragraph"
    >
      &larr; Back
    </a>

    <div class="-container -grid s:gap-y-0 gap-y-64">
      <!-- Title & bio -->
      <div class="col-span-full s:col-span-4 s:col-start-11">
        <div class="pl-[5.5rem] s:pl-0">
          <h1
            class="text-h1 s:text-h2 font-medium mb-32 s:pl-0"
            data-animation="title"
          >
            About
          </h1>
        </div>
        <p
          class="font-medium text-[1rem] s:text-[1.2rem] m:text-[1rem] leading-tight"
          data-animation="paragraph"
        >
          <span class="block">
            I'm Chris Howell, a Creative Designer &amp; Director based on the Gold Coast, Australia.
          </span>
          <span class="block">
            With over 20 years of experience in branding, UI/UX, and digital content,
            I help businesses communicate clearly and look their best. I combine creativity
            and strategy to deliver work that resonates with purpose and precision.
          </span>
          <span class="block">
            Currently available for select projects and creative direction.
          </span>
        </p>
      </div>

      <!-- Experience (left) -->
      <div class="col-span-full s:col-span-6 mt-64 s:mt-100">
        <p class="text-xl font-medium mb-20" data-animation="paragraph">Experience</p>
        <div class="grid grid-cols-1" data-animation="paragraph">
          <div class="py-16">
            <p class="text-xs font-medium mb-4 opacity-50">2020 &mdash; Present</p>
            <p class="text-base font-medium">Creative Director</p>
            <p class="text-base opacity-50">Halfnine Design</p>
          </div>
          <div class="py-16">
            <p class="text-xs font-medium mb-4 opacity-50">2018 &mdash; 2024</p>
            <p class="text-base font-medium">Lead Designer</p>
            <p class="text-base opacity-50">Sunland Group</p>
          </div>
          <div class="py-16">
            <p class="text-xs font-medium mb-4 opacity-50">2019 &mdash; 2023</p>
            <p class="text-base font-medium">Brand &amp; UI/UX Designer</p>
            <p class="text-base opacity-50">Exintech</p>
          </div>
          <div class="py-16">
            <p class="text-xs font-medium mb-4 opacity-50">2016 &mdash; 2020</p>
            <p class="text-base font-medium">Designer</p>
            <p class="text-base opacity-50">City of Gold Coast</p>
          </div>
          <div class="py-16">
            <p class="text-xs font-medium mb-4 opacity-50">2022 &mdash; 2024</p>
            <p class="text-base font-medium">Design &amp; Marketing</p>
            <p class="text-base opacity-50">Abedian &amp; Co</p>
          </div>
          <div class="py-16">
            <p class="text-xs font-medium mb-4 opacity-50">2005 &mdash; 2016</p>
            <p class="text-base font-medium">Founder &amp; Designer</p>
            <p class="text-base opacity-50">Halfnine Design</p>
          </div>
        </div>
      </div>

      <!-- Skill Set (right) -->
      <div class="col-span-full s:col-start-8 s:col-span-9 mt-64 s:mt-100">
        <p class="text-xl font-medium mb-20" data-animation="paragraph">Skill Set</p>
        <div class="grid grid-cols-1 s:grid-cols-2" data-animation="paragraph">
          <div class="py-16 s:pr-20">
            <p class="text-base font-medium">Design</p>
            <p class="text-base opacity-50">InDesign, Illustrator, Photoshop, Lightroom, Figma, Sketch, Canva</p>
          </div>
          <div class="py-16 s:pr-20">
            <p class="text-base font-medium">SEO &amp; Analytics</p>
            <p class="text-base opacity-50">Seoptimer, Semrush, Hotjar, Moz, Google Analytics</p>
          </div>
          <div class="py-16 s:pr-20">
            <p class="text-base font-medium">CMS</p>
            <p class="text-base opacity-50">Contentful, Sanity, Strapi, WordPress, Squarespace</p>
          </div>
          <div class="py-16 s:pr-20">
            <p class="text-base font-medium">Marketing</p>
            <p class="text-base opacity-50">Mailchimp, Hootsuite, Buffer, Active Campaign, Klaviyo</p>
          </div>
          <div class="py-16 s:pr-20">
            <p class="text-base font-medium">Web</p>
            <p class="text-base opacity-50">HTML, CSS, MJML, Webflow, Framer, Git</p>
          </div>
          <div class="py-16 s:pr-20">
            <p class="text-base font-medium">User Testing</p>
            <p class="text-base opacity-50">Maze, User Testing, Optimal, Dovetail</p>
          </div>
          <div class="py-16 s:pr-20">
            <p class="text-base font-medium">AI &amp; Agents</p>
            <p class="text-base opacity-50">Claude, Gemini, ChatGPT, Grok, Cursor, Bolt, Make, n8n, Midjourney</p>
          </div>
          <div class="py-16 s:pr-20">
            <p class="text-base font-medium">Presentation</p>
            <p class="text-base opacity-50">PowerPoint, Keynote, Prezi, Google Slides</p>
          </div>
          <div class="py-16 s:pr-20">
            <p class="text-base font-medium">Frameworks</p>
            <p class="text-base opacity-50">React, Astro, Tailwind, Bulma, Bootstrap</p>
          </div>
          <div class="py-16 s:pr-20">
            <p class="text-base font-medium">Advertising</p>
            <p class="text-base opacity-50">Google Ads, Meta Ads, TikTok Ads, Print Ads</p>
          </div>
          <div class="py-16 s:pr-20">
            <p class="text-base font-medium">DAM</p>
            <p class="text-base opacity-50">Bynder, ThirdLight</p>
          </div>
          <div class="py-16 s:pr-20">
            <p class="text-base font-medium">3D Design</p>
            <p class="text-base opacity-50">SketchUp, Spline, AutoCAD, Revit, Blender</p>
          </div>
          <div class="py-16 s:pr-20">
            <p class="text-base font-medium">Video</p>
            <p class="text-base opacity-50">Premiere Pro, After Effects, Final Cut, Lottie, Adobe Animate</p>
          </div>
          <div class="py-16 s:pr-20">
            <p class="text-base font-medium">CRM / Project</p>
            <p class="text-base opacity-50">Salesforce, Wrike, HubSpot, Monday, Basecamp</p>
          </div>
        </div>
      </div>
      
    </div>
  </section>
</BaseLayout>
