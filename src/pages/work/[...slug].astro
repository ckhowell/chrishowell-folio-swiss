---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
const { title, client, description, year, services, contribution, agency } =
  project.data;

// Featured projects list for footer navigation
const allProjects = await getCollection('projects');
const sorted = allProjects
  .filter((p) => p.data.isFeatured)
  .sort(
    (a, b) =>
      new Date(b.data.publishDate).getTime() -
      new Date(a.data.publishDate).getTime()
  );
const getPreviewImage = (item: (typeof sorted)[number]) =>
  item.data.hoverimage ??
  (Array.isArray(item.data.image) ? item.data.image[0] : item.data.image);
const firstPreviewItem = sorted.find((item) => item.slug !== project.slug) ?? sorted[0];
const firstPreviewImage = firstPreviewItem ? getPreviewImage(firstPreviewItem) : '';
import ProjectSection from '../../components/mdx/ProjectSection.astro';
import ProjectMedia from '../../components/mdx/ProjectMedia.astro';
import ProjectText from '../../components/mdx/ProjectText.astro';

const components = {
  ProjectSection,
  ProjectMedia,
  ProjectText,
};
---

<BaseLayout title={`${title} | Chris Howell`} bodyClass="work">
  <!-- Back link -->
  <a
    href="/"
    class="fixed top-0 right-0 p-20 text-base font-medium z-50"
    data-animation="paragraph"
  >
    &larr; Back
  </a>

  <!-- Metadata grid -->
  <section class="pt-[50vh] pb-64 s:pb-100">
    <div class="-container -grid">
      <!-- Title -->
      <div class="col-span-full s:col-span-5">
        <h3
          class="font-medium text-[1rem] s:text-[1.2rem] m:text-[2rem] leading-tight"
          data-animation="title"
        >
          {title}
        </h3>
      </div>

      <!-- Description -->
      {description && (
        <div class="col-span-full s:col-span-4 s:col-start-8 mt-32 s:mt-0">
          <p
            class="text-base font-medium leading-tight"
            data-animation="paragraph"
          >
            {description}
          </p>
        </div>
      )}

      <!-- Details column -->
      <div class="col-span-full s:col-span-3 s:col-start-13 mt-32 s:mt-0 space-y-16">
        {year && (
          <div data-animation="paragraph">
            <p class="text-xs uppercase tracking-wide opacity-50">Year</p>
            <p class="text-base font-medium">{year}</p>
          </div>
        )}
        {services && services.length > 0 && (
          <div data-animation="paragraph" data-animation-delay="0.1">
            <p class="text-xs uppercase tracking-wide opacity-50">Services</p>
            <p class="text-base font-medium">{services.join(', ')}</p>
          </div>
        )}
        {agency && (
          <div data-animation="paragraph" data-animation-delay="0.2">
            <p class="text-xs uppercase tracking-wide opacity-50">Agency</p>
            <p class="text-base font-medium">{agency}</p>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Project images (rendered markdown/MDX body) -->
  <section class="project-media overflow-hidden rounded-2xl w-full col-span-full s:col-span-17 ">
    <Content components={components} />
  </section>

  <!-- Next project -->
  {sorted.length > 0 && (
    <section class="next-project border-t-1 border-black/20 pt-48 s:pt-80 pb-64 s:pb-120">
      <div class="-container -grid">
        <div class="col-span-full s:col-span-5 s:col-start-8">
          <p
            class="text-xs uppercase tracking-wide opacity-50 mb-8"
            data-animation="paragraph"
          >
            All Projects
          </p>
          <div class="space-y-8">
            {sorted
              .filter((item) => item.slug !== project.slug)
              .map((item) => (
                <a
                  href={`/work/${item.slug}`}
                  class="next-project__link text-h5 s:text-h5 font-medium block"
                  data-preview-src={getPreviewImage(item)}
                  data-animation="title"
                >
                  {item.data.title}
                </a>
            ))}
          </div>
        </div>
        <div class="next-project__preview" aria-hidden="true">
          <div class="next-project__preview-inner">
            {firstPreviewImage && (
              <img
                class="next-project__preview-img"
                src={firstPreviewImage}
                alt=""
              />
            )}
          </div>
        </div>
      </div>
    </section>
  )}
</BaseLayout>
